# Host directory for all projects (repos will be cloned here)
WORKSPACE_PATH=/opt/mcp-workspace

# Default GitHub user for clone() shorthand
GITHUB_USER=OlegKarenkikh

# Command execution timeout (seconds)
CMD_TIMEOUT=120

# Max output length returned by run() tool (chars)
MAX_OUTPUT=4000

# Max file content length returned by cat() tool (chars)
MAX_FILE_READ=8000
