# Host directory for all projects
WORKSPACE_PATH=/opt/mcp-workspace

# Default GitHub user for clone() shorthand
GITHUB_USER=OlegKarenkikh

# Basic Auth credentials for Traefik
# Generate: htpasswd -nbB oleg YourPassword
# IMPORTANT: double every $ sign for docker-compose!
# Example: oleg:$2y$05$abc... -> oleg:$$2y$$05$$abc...
AUTH_CREDENTIALS=oleg:$$2y$$05$$your_hash_here

# Command execution timeout (seconds)
CMD_TIMEOUT=120

# Max output length (chars)
MAX_OUTPUT=4000

# Max file read length (chars)
MAX_FILE_READ=8000
